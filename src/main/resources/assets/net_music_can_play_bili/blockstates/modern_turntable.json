{
  "multipart": [
    { "when": { "facing": "north" }, "apply": { "model": "net_music_can_play_bili:block/modern_turntable" } },
    { "when": { "facing": "east" }, "apply": { "model": "net_music_can_play_bili:block/modern_turntable", "y": 90 } },
    { "when": { "facing": "south" }, "apply": { "model": "net_music_can_play_bili:block/modern_turntable", "y": 180 } },
    { "when": { "facing": "west" }, "apply": { "model": "net_music_can_play_bili:block/modern_turntable", "y": 270 } },
    {
      "when": { "facing": "north", "has_disc": "true" },
      "apply": { "model": "net_music_can_play_bili:block/modern_turntable_disc" }
    },
    {
      "when": { "facing": "east", "has_disc": "true" },
      "apply": { "model": "net_music_can_play_bili:block/modern_turntable_disc", "y": 90 }
    },
    {
      "when": { "facing": "south", "has_disc": "true" },
      "apply": { "model": "net_music_can_play_bili:block/modern_turntable_disc", "y": 180 }
    },
    {
      "when": { "facing": "west", "has_disc": "true" },
      "apply": { "model": "net_music_can_play_bili:block/modern_turntable_disc", "y": 270 }
    }
  ]
}
